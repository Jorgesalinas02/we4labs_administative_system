{
  "name": "we4labs-admin",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @we4labs/web dev",
    "dev:clean": "rm -rf apps/web/.next && pnpm dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "db:generate": "pnpm --filter @we4labs/db generate",
    "db:migrate": "pnpm --filter @we4labs/db migrate",
    "db:seed": "pnpm --filter @we4labs/db seed",
    "db:studio": "pnpm --filter @we4labs/db studio",
    "test": "pnpm --filter @we4labs/shared test"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp"]
  }
}

# --- Base de datos (elige una) ---
# Local con Docker: docker compose up -d →
# DATABASE_URL=postgres://we4labs:we4labs@localhost:5433/we4labs
#
# Neon (https://neon.tech): en el dashboard copia la cadena; suele incluir ?sslmode=require
# Usa la URL "directa" para migraciones (drizzle-kit / pnpm db:migrate) si Neon lo indica;
# la URL "pooled" (-pooler) conviene para Next.js en producción / serverless.
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

DATABASE_URL=postgres://we4labs:we4labs@localhost:5433/we4labs

# ── Clerk (autenticación) ─────────────────────────────────────────────────────
# Obtén tus claves en https://dashboard.clerk.com → tu app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxx
CLERK_SECRET_KEY=sk_test_xxxx

# URLs de redirección (Clerk las necesita)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Caché de lecturas por ruta (segundos). Reduce viajes a Neon al navegar; `0` la desactiva.
# DATA_CACHE_SECONDS=45

# UUID del tenant en desarrollo (evita SELECT al primer tenant en cada request).
# Tras `pnpm db:seed` en BD vacía: 00000000-0000-4000-a000-000000000001 (ver seed).
# Si ya tenías datos: `select id from tenants where slug = 'we4labs-demo';`
# DEV_TENANT_ID=00000000-0000-4000-a000-000000000001

# Amazon Cognito (JWT access token + custom:tenant_id en claim)
# COGNITO_USER_POOL_ID=
# COGNITO_CLIENT_ID=

# Pusher: cliente (público) + servidor (firma canales privados)
# NEXT_PUBLIC_PUSHER_KEY=
# NEXT_PUBLIC_PUSHER_CLUSTER=mt1
# PUSHER_APP_ID=
# PUSHER_KEY=
# PUSHER_SECRET=
# PUSHER_CLUSTER=mt1

# Producción AWS (Lambda + API Gateway + Aurora + RDS Proxy)
# Usar Secrets Manager / SSM en lugar de .env en runtime
